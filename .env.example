# ---- Core Telegram Bot ----
TELEGRAM_BOT_TOKEN=
PERSONAL_CHAT_ID=
ALLOWED_TELEGRAM_USER_IDS=
MONITORED_GROUP_CHAT_ID=0

# ---- Persistence & Defaults ----
DB_PATH=reminder_agent.db
DEFAULT_TIMEZONE=UTC
ARCHIVE_RETENTION_DAYS=30
MESSAGE_RETENTION_DAYS=14
REQUIRE_TOPIC_ON_ADD=false
DATETIME_PARSE_DEBUG=false

# ---- Local LLM (Ollama) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_TEXT_MODEL=
OLLAMA_VISION_MODEL=
OLLAMA_AUTOSTART=true
OLLAMA_START_TIMEOUT_SECONDS=20
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
OLLAMA_USE_HIGHEST_VRAM_GPU=true

# ---- Speech-to-Text ----
STT_PROVIDER=faster_whisper
STT_MODEL=large-v3
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto
STT_USE_HIGHEST_VRAM_GPU=true

# ---- Userbot Ingest (Telethon) ----
USERBOT_ENABLED=false
USERBOT_API_ID=
USERBOT_API_HASH=
USERBOT_SESSION_NAME=reminder_userbot
USERBOT_INGEST_CHAT_IDS=
USERBOT_ALLOW_SENDING=false
USERBOT_SEND_WHITELIST_CHAT_IDS=

# ---- Auto Summary ----
AUTO_SUMMARY_ENABLED=false
AUTO_SUMMARY_CHAT_IDS=
AUTO_SUMMARY_MIN_INTERVAL_MINUTES=15

# ---- Gmail Ingest (multi-account) ----
GMAIL_ENABLED=false
GMAIL_POLL_INTERVAL_MINUTES=2
GMAIL_GLOBAL_QUERY=label:inbox newer_than:2d -category:promotions -category:social
GMAIL_USE_LLM_IMPORTANCE=true
GMAIL_REQUIRE_RULE_MATCH=true
GMAIL_SUMMARY_ENABLED=true
GMAIL_DRAFT_ENABLED=false
GMAIL_ACCOUNTS_JSON=[]
GMAIL_ACCOUNTS_FILE=
# If GMAIL_ACCOUNTS_FILE is set, it takes precedence over GMAIL_ACCOUNTS_JSON.
# Example: GMAIL_ACCOUNTS_FILE=../secrets/gmail_accounts.json
# Put per-account filter lists in a separate JSON and reference it as `filter_keys_file`
# inside each account object in gmail_accounts.json.
GMAIL_DELIVERY_MODE=immediate
GMAIL_BATCH_INTERVAL_MINUTES=15
GMAIL_URGENT_SCORE_THRESHOLD=0.85
GMAIL_THREAD_COOLDOWN_MINUTES=90
GMAIL_VIP_SENDER_SCORE_BOOST=0.5
GMAIL_TRUSTED_DOMAIN_SCORE_BOOST=0.5
GMAIL_SYSTEM_SENDER_SCORE_BOOST=0.15
GMAIL_ATTACHMENT_SCORE_BOOST=0.20
# GMAIL_ACCOUNTS_JSON item keys (per account):
# account_id, credentials_file, token_file, query,
# sender_allowlist, sender_blocklist, keyword_include, keyword_exclude,
# sender_vip, sender_system, sender_trusted_domains,
# filter_keys_file,
# attachment_keyword_include,
# risky_tlds, shortener_domains, suspicious_phrases,
# promotional_phrases, urgent_subject_phrases,
# telegram_chat_id
#
# Example filter_keys_file JSON:
# {
#   "risky_tlds": ["zip", "click", "xyz"],
#   "shortener_domains": ["bit.ly", "tinyurl.com"],
#   "suspicious_phrases": ["verify your account", "urgent action required"],
#   "promotional_phrases": ["unsubscribe", "newsletter"],
#   "urgent_subject_phrases": ["urgent", "action required"]
# }

# ---- Google Calendar Sync ----
GCAL_SYNC_ENABLED=false
GCAL_CALENDAR_ID=primary
# Comma-separated list of calendar IDs to import events from.
# Leave empty to default to GCAL_CALENDAR_ID.
GCAL_SYNC_FROM_CALENDAR_IDS=
GCAL_CREDENTIALS_FILE=

# ---- Digest Schedule (local timezone preferred) ----
DIGEST_TIMES_LOCAL=
DIGEST_HOUR_LOCAL=9
DIGEST_MINUTE_LOCAL=0

# Legacy/compat fallback keys (used only if local variants are empty)
DIGEST_TIMES_UTC=
DIGEST_HOUR_UTC=9
DIGEST_MINUTE_UTC=0
